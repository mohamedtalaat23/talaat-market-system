{
  "name": "@talaat-market/desktop",
  "version": "1.0.0",
  "description": "Talaat Market — Electron Desktop Shell",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsc --project tsconfig.json && wait-on http://localhost:5173 && wait-on http://localhost:3001/api/v1/health && NODE_ENV=development electron .",
    "build": "tsc --project tsconfig.json && electron-builder",
    "build:win": "tsc --project tsconfig.json && electron-builder --win",
    "build:linux": "tsc --project tsconfig.json && electron-builder --linux",
    "typecheck": "tsc --noEmit",
    "pack": "electron-builder --dir"
  },
  "dependencies": {
    "electron-store": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "electron": "^39.8.1",
    "electron-builder": "^26.8.1",
    "typescript": "^5.6.0",
    "wait-on": "^8.0.0"
  }
}
