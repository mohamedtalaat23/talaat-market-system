{
  "name": "talaat-market",
  "version": "1.0.0",
  "description": "Talaat Market — Supermarket Management System",
  "private": true,
  "workspaces": [
    "packages/client",
    "packages/server",
    "packages/desktop"
  ],
  "scripts": {
    "dev": "concurrently --names \"SERVER,CLIENT,ELECTRON\" --prefix-colors \"green,blue,yellow\" \"npm run dev --workspace=packages/server\" \"npm run dev --workspace=packages/client\" \"npm run dev --workspace=packages/desktop\"",
    "dev:server": "npm run dev --workspace=packages/server",
    "dev:client": "npm run dev --workspace=packages/client",
    "dev:desktop": "npm run dev --workspace=packages/desktop",
    "build": "npm run build --workspace=packages/server && npm run build --workspace=packages/client && npm run build --workspace=packages/desktop",
    "build:win": "npm run build --workspace=packages/server && npm run build --workspace=packages/client && npm run build:win --workspace=packages/desktop",
    "build:server": "npm run build --workspace=packages/server",
    "build:client": "npm run build --workspace=packages/client",
    "build:desktop": "npm run build --workspace=packages/desktop",
    "lint": "eslint \"packages/*/src/**/*.{ts,tsx}\" --max-warnings 0",
    "lint:fix": "eslint \"packages/*/src/**/*.{ts,tsx}\" --fix",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"packages/*/src/**/*.{ts,tsx,css}\"",
    "typecheck": "npm run typecheck --workspace=packages/server && npm run typecheck --workspace=packages/client && npm run typecheck --workspace=packages/desktop",
    "test:client": "npm run test --workspace=packages/client",
    "test:e2e": "npm run test:e2e --workspace=packages/client",
    "db:migrate": "npm run migrate --workspace=packages/server",
    "db:rollback": "npm run migrate:rollback --workspace=packages/server",
    "db:seed": "npm run seed --workspace=packages/server",
    "clean": "node scripts/clean.cjs"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "concurrently": "^10.0.3",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "overrides": {
    "esbuild": "^0.25.0"
  }
}
