# ============================================================
# Talaat Market System — Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================

# ------ Application ------
NODE_ENV=development
APP_NAME="Talaat Market"

# ------ Express Server ------
# Port for the Express API server (auto-assigned in Electron mode)
SERVER_PORT=3001
# Host — always localhost for local mode; change to 0.0.0.0 for LAN mode
SERVER_HOST=localhost

# ------ PostgreSQL Database ------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=talaat_market
DB_USER=talaat_user
DB_PASSWORD=your_secure_password_here
DB_POOL_MIN=2
DB_POOL_MAX=10

# ------ Session ------
SESSION_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_STRING

# ------ JWT Authentication ------
# Generate a strong random secret: openssl rand -hex 64
# Must be at least 32 characters long
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_STRING_JWT_32_CHARS
JWT_EXPIRES_IN=12h

# ------ Logging ------
# Options: error | warn | info | debug
LOG_LEVEL=info
# Directory for log files (relative to server package root)
LOG_DIR=logs

# ------ Backup ------
# Directory where database backups are stored
BACKUP_DIR=~/TalaatMarket/backups

# ------ Electron ------
# Path to pg_dump binary (required for backups)
PGDUMP_PATH=pg_dump
